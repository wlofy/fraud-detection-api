# Copy to .env and adjust as needed.

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=transactions

# Which trained model the API/consumer use for scoring: isolation_forest | autoencoder
SCORING_MODEL=isolation_forest

# Replay throughput for the producer (transactions/second; 0 = as fast as possible)
PRODUCER_RATE=50

# Expected fraction of anomalies — sets the decision threshold from training scores
CONTAMINATION=0.0017
